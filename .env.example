# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL-compatible URL (Railway MySQL, PlanetScale, Aiven, etc.)
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-random-secret-min-32-chars

ADMIN_EMAIL=admin@argbuilder.io
ADMIN_PASSWORD=your-secure-password

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Google AI (Gemini) — recommended, generous free tier
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=your-google-ai-api-key
LLM_MODEL=gemini-2.5-flash

# OpenAI alternative — uncomment and comment out Google AI above
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ─── Image Generation ─────────────────────────────────────────────────────────
# Uses OpenAI DALL-E. Leave empty to disable image generation.
# IMAGE_API_KEY defaults to LLM_API_KEY if not set.
IMAGE_API_KEY=sk-...
IMAGE_MODEL=dall-e-3

# ─── File Storage (S3-compatible) ─────────────────────────────────────────────
# Option A: Cloudflare R2 (recommended — free 10 GB, no egress fees)
#   1. Create R2 bucket at dash.cloudflare.com
#   2. Create API token with R2 permissions
#   3. Find your Account ID in the Cloudflare dashboard
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Enable R2 public access in the bucket settings, then set the public URL:
S3_PUBLIC_URL=https://pub-<TOKEN>.r2.dev

# Option B: AWS S3 — uncomment and leave S3_ENDPOINT empty
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=...
# S3_ENDPOINT=
# S3_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com

# ─── Stripe (optional) ────────────────────────────────────────────────────────
# Leave empty to disable billing features
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
STRIPE_PRICE_IMPL_STANDARD=price_...
STRIPE_PRICE_IMPL_CUSTOM=price_...

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
